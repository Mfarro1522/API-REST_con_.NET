<Window x:Class="MakriFormas.NewProformaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Nueva Proforma | Makricolors Publicidad"
        Height="840" Width="1320"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#069494" />
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="#FCE883" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFEFB" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="#FFF3F6" />
        <SolidColorBrush x:Key="TextMainBrush" Color="#1B1E1F" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#4F5C60" />

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <EventSetter Event="GotKeyboardFocus" Handler="InputTextBox_GotKeyboardFocus" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="InputTextBox_PreviewMouseLeftButtonDown" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Border CornerRadius="12" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource TropicalYellowTintBrush}">
                    <Grid Margin="16,18,16,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Makricolors Publicidad" FontSize="18" FontWeight="Black" />
                            <TextBlock Text="Sistema de Proformas" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,18,0,0">
                            <Button Style="{StaticResource NavButton}" Content="🏠  Dashboard" Click="CloseAndReturn_Click" />
                            <Border Background="{StaticResource PrimaryLightBrush}" CornerRadius="8" Padding="12,10" Margin="0,4,0,0">
                                <TextBlock Text="📝  Nueva Proforma" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" />
                            </Border>
                            <Button Style="{StaticResource NavButton}" Content="📦  Inventario" Click="OpenInventory_Click" />
                            <Button Style="{StaticResource NavButton}" Content="🗂️  Historial" Click="OpenHistory_Click" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse Width="34" Height="34" Fill="{StaticResource TropicalPinkBrush}" />
                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="Usuario Admin" FontWeight="Bold" FontSize="12" />
                                <TextBlock Text="Arquitecto del Sistema" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="64" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1">
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="CREACIÓN DE PROFORMA" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,6,0" />
                                <TextBlock Text="Base de datos local conectada" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="28,20,28,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="CREACIÓN DE DOCUMENTO" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                    <TextBlock x:Name="txtProformaCode" Text="PF-0000-0000" FontSize="42" FontWeight="Black" Foreground="{StaticResource TextMainBrush}" />
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Text="Generando una nueva cotización para materiales publicitarios y servicios de instalación." />
                                </StackPanel>

                                <Border Background="White" CornerRadius="10" BorderBrush="#E8E8E8" BorderThickness="1" Padding="18" Margin="0,0,0,12">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <TextBlock DockPanel.Dock="Left" Text="Datos del Cliente" FontSize="20" FontWeight="Bold" />
                                            <TextBlock DockPanel.Dock="Right" Text="Campo Requerido" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="11" />
                                        </DockPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Margin="0,0,8,8">
                                                <TextBlock Text="NOMBRE DEL CLIENTE" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBox x:Name="txtCliente" Padding="8" Background="#F0F0F0" BorderThickness="0" Text="Razón Social / Nombre" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="8,0,0,8">
                                                <TextBlock Text="RUC / DNI" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBox x:Name="txtRuc" Padding="8" Background="#F0F0F0" BorderThickness="0" Text="" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                                                <TextBlock Text="DIRECCIÓN" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBox x:Name="txtDireccion" Padding="8" Background="#F0F0F0" BorderThickness="0" Text="Dirección de entrega" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="White" CornerRadius="10" BorderBrush="#E8E8E8" BorderThickness="1" Padding="18" Margin="0,0,0,12">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,12">
                                            <TextBlock DockPanel.Dock="Left" Text="Selección de Productos" FontSize="20" FontWeight="Bold" />
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="Registrar faltante" Click="RegisterMissingProduct_Click" Padding="10,6" Margin="0,0,8,0" />
                                                <Button Content="+ Añadir Ítem" Click="AddProduct_Click" Padding="10,6" Background="{StaticResource PrimaryBrush}" Foreground="White" BorderThickness="0" FontWeight="Bold" />
                                            </StackPanel>
                                        </DockPanel>

                                        <Border Background="#F1F1F1" CornerRadius="8" Padding="10" Margin="0,0,0,12">
                                            <Grid>
                                                <TextBlock x:Name="txtCatalogSearchPlaceholder"
                                                           Text="🔍  Buscar producto por SKU, nombre o categoría..."
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="12"
                                                           IsHitTestVisible="False" />
                                                <TextBox x:Name="txtCatalogSearch"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         VerticalContentAlignment="Center"
                                                         TextChanged="CatalogSearch_TextChanged" />
                                            </Grid>
                                        </Border>

                                        <TextBlock x:Name="txtCatalogNoResults"
                                                   Text="No hay coincidencias en catálogo. Puedes registrar este producto con el botón 'Registrar faltante'."
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Visibility="Collapsed"
                                                   Margin="0,0,0,8"
                                                   TextWrapping="Wrap" />

                                        <ListBox x:Name="lbProductMatches"
                                                 MaxHeight="120"
                                                 Margin="0,0,0,12"
                                                 SelectionChanged="ProductMatches_SelectionChanged"
                                                 BorderBrush="#DADADA"
                                                 BorderThickness="1"
                                                 Background="#FCFCFC">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="6,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="90" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Sku}" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="8,0" />
                                                        <TextBlock Grid.Column="2" Text="{Binding UnitPriceDisplay}" HorizontalAlignment="Right" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="2*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Descripción" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Grid.Column="1" Text="Unidad" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="Dimensiones" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="3" Text="Cant" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="4" Text="P. Unitario" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" />
                                            <TextBlock Grid.Column="5" Text="Total" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" />
                                        </Grid>

                                        <ItemsControl x:Name="icItems">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F8F8F8" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="3*" />
                                                                <ColumnDefinition Width="90" />
                                                                <ColumnDefinition Width="2*" />
                                                                <ColumnDefinition Width="60" />
                                                                <ColumnDefinition Width="2*" />
                                                                <ColumnDefinition Width="2*" />
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Descripción -->
                                                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" />

                                                            <!-- Unidad -->
                                                            <ComboBox Grid.Column="1"
                                                                      SelectedValue="{Binding Unidad, UpdateSourceTrigger=PropertyChanged}"
                                                                      SelectedValuePath="Tag"
                                                                      VerticalAlignment="Center"
                                                                      FontSize="11"
                                                                      SelectionChanged="ItemUnidad_SelectionChanged">
                                                                <ComboBoxItem Tag="unidad" Content="und" />
                                                                <ComboBoxItem Tag="m2" Content="m²" />
                                                                <ComboBoxItem Tag="metro" Content="metro" />
                                                                <ComboBoxItem Tag="kg" Content="kg" />
                                                                <ComboBoxItem Tag="oz" Content="oz" />
                                                            </ComboBox>

                                                            <!-- Dimensiones dinámicas (m2: Ancho × Alto | metro: Longitud) -->
                                                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                                                <!-- m2: campos Ancho × Alto -->
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                                            Visibility="{Binding IsAreaBased, Converter={StaticResource BoolToVisible}}">
                                                                    <TextBox Width="38" Text="{Binding Ancho, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" BorderThickness="1" BorderBrush="#DDD" />
                                                                    <TextBlock Text=" × " VerticalAlignment="Center" FontSize="11" />
                                                                    <TextBox Width="38" Text="{Binding Alto, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" BorderThickness="1" BorderBrush="#DDD" />
                                                                </StackPanel>
                                                                <!-- metro: campo Longitud -->
                                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                                            Visibility="{Binding IsMetro, Converter={StaticResource BoolToVisible}}">
                                                                    <TextBox Width="60" Text="{Binding Longitud, UpdateSourceTrigger=PropertyChanged}" TextAlignment="Center" BorderThickness="1" BorderBrush="#DDD" />
                                                                    <TextBlock Text=" m" VerticalAlignment="Center" FontSize="11" />
                                                                </StackPanel>
                                                                <!-- otras: guión -->
                                                                <TextBlock Text="—" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#CCC"
                                                                           Visibility="{Binding IsSimpleUnit, Converter={StaticResource BoolToVisible}}" />
                                                            </Grid>

                                                            <!-- Cantidad -->
                                                            <TextBox Grid.Column="3" VerticalAlignment="Center" Width="46" HorizontalAlignment="Center" TextAlignment="Center"
                                                                     Text="{Binding Cantidad, UpdateSourceTrigger=PropertyChanged}" BorderThickness="1" BorderBrush="#DDD" />

                                                            <!-- Precio unitario -->
                                                            <TextBox Grid.Column="4" VerticalAlignment="Center" Width="70" Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Right" TextAlignment="Right" BorderThickness="1" BorderBrush="#DDD" />

                                                            <!-- Total -->
                                                            <TextBlock Grid.Column="5" Text="{Binding Total, StringFormat=S/ {0:N2}}" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Background="White" CornerRadius="10" BorderBrush="#E8E8E8" BorderThickness="1" Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="Parámetros de Diseño e Instalación" FontSize="20" FontWeight="Bold" Margin="0,0,0,12" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Margin="0,0,8,8">
                                                <TextBlock Text="FECHA DE ENTREGA" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                                <StackPanel Orientation="Horizontal">
                                                    <DatePicker x:Name="dpFecha" Width="140" />
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Margin="8,0,0,8">
                                                <TextBlock Text="OBSERVACIONES DE DISEÑADOR" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBox x:Name="txtDesignerObservations" Height="70" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="" />
                                            </StackPanel>

                                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                                                <TextBlock Text="OBSERVACIONES DE INSTALADOR" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                                <TextBox x:Name="txtInstallerObservations" Height="90" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="2" Margin="18,0,18,14" Padding="16" CornerRadius="14" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

							<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
								<TextBlock Text="Total Cotización:" FontSize="16" FontWeight="Bold" Margin="0,0,10,0"/>
								<TextBlock x:Name="txtOverallTotal" Text="S/ 0.00" FontSize="24" FontWeight="Black" Foreground="{StaticResource PrimaryBrush}"/>
							</StackPanel>

							<StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Guardar Proforma" Click="SaveProforma_Click" Padding="16,8" BorderThickness="0" Margin="0,0,8,0" />
                                <Button Content="Exportar PDF" Click="ExportPdf_Click" Padding="16,8" BorderThickness="0" Foreground="White" Background="{StaticResource PrimaryBrush}" FontWeight="Bold" />
							</StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
