<UserControl x:Class="MakriFormas.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,24">

            <!-- Page Title -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="PANEL PRINCIPAL" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="Dashboard" FontSize="36" FontWeight="Black" />
                </StackPanel>
                <TextBlock Grid.Column="1" TextAlignment="Right" VerticalAlignment="Bottom"
                           Foreground="{StaticResource TextMutedBrush}"
                           Text="Gestión de ventas, proformas e inventario&#x0a;Flujo optimizado para operación diaria" />
            </Grid>

            <!-- Hero Cards Row -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- CTA Card -->
                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,10,0" Background="{StaticResource TropicalYellowTintBrush}" MinHeight="190">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Acción recomendada" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Text="Crear nueva proforma" FontSize="26" FontWeight="Bold" Margin="0,4,0,8" />
                            <TextBlock TextWrapping="Wrap" Width="380"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="Genera una cotización en menos de 1 minuto con cliente, ítems y total automático para exportar a PDF." />
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Width="180" Content="Nueva Proforma"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="OpenNewProforma_Click" />
                                <Button Width="160" Margin="8,0,0,0"
                                        Content="Gestionar Inventario"
                                        Click="OpenInventory_Click" />
                            </StackPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Background="{StaticResource TropicalYellowBrush}"
                                CornerRadius="12" Padding="16" Margin="12,0,0,0">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Proformas hoy" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock x:Name="txtDashboardProformasToday" Text="0" FontSize="22" FontWeight="Black"
                                           Foreground="{StaticResource BrandDarkBrush}" Margin="0,4,0,6" />
                                <TextBlock x:Name="txtDashboardProformasSubtitle" Text="Creadas hoy en total"
                                           TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Status Card -->
                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}"
                        Background="{StaticResource TropicalPinkTintBrush}" MinHeight="190">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock DockPanel.Dock="Left" Text="ESTADO DEL SISTEMA"
                                       FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <Ellipse DockPanel.Dock="Right" Width="10" Height="10"
                                     Fill="{StaticResource SuccessBrush}" />
                        </DockPanel>
                        <TextBlock Text="Operación estable" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="DB Local" Foreground="{StaticResource TextMutedBrush}" Margin="0,4" />
                            <TextBlock Grid.Column="1" Text="Conectada" FontWeight="Bold" Margin="0,4" Foreground="{StaticResource SuccessBrush}" />
                            <TextBlock Grid.Row="1" Text="Sincronización" Foreground="{StaticResource TextMutedBrush}" Margin="0,4" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Local" FontWeight="Bold" Margin="0,4" />
                            <TextBlock Grid.Row="2" Text="Proformas totales" Foreground="{StaticResource TextMutedBrush}" Margin="0,4" />
                            <TextBlock x:Name="txtDashboardProformaTotal" Grid.Row="2" Grid.Column="1" Text="—" FontWeight="Bold" Margin="0,4" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- KPI Cards -->
            <UniformGrid Columns="3" Margin="0,0,0,16">
                <Border Margin="0,0,8,0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Productos en catálogo" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold" />
                        <TextBlock x:Name="txtDashboardProducts" Text="0" FontSize="32" FontWeight="Black" />
                        <TextBlock x:Name="txtDashboardCategories" Text="0 categorías"
                                   Foreground="{StaticResource SuccessBrush}" FontSize="10" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Margin="4,0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Stock Total" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" FontWeight="Bold" />
                        <TextBlock x:Name="txtDashboardStock" Text="0" FontSize="32" FontWeight="Black" />
                        <TextBlock x:Name="txtDashboardAvgPrice" Text="Precio promedio: S/ 0.00"
                                   Foreground="{StaticResource BrandDarkBrush}" FontSize="10" FontWeight="Bold" />
                    </StackPanel>
                </Border>
                <Border Margin="8,0,0,0" Style="{StaticResource CardBorderStyle}"
                        Background="{StaticResource TropicalYellowTintBrush}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Atajo rápido" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="Actualiza tu stock" FontSize="21" FontWeight="Black" Margin="0,4,0,10" />
                        <Button Content="Abrir Inventario" Click="OpenInventory_Click" Style="{StaticResource PrimaryButton}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Recent Products Table -->
            <Border Style="{StaticResource CardBorderStyle}" Padding="0,0,0,10">
                <StackPanel>
                    <Grid Margin="16,14,16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Productos Recientes" FontSize="18" FontWeight="Bold" />
                        <TextBlock Grid.Column="1" Text="Fuente: SQLite"
                                   Foreground="{StaticResource BrandDarkBrush}"
                                   FontWeight="Bold" VerticalAlignment="Center" />
                    </Grid>

                    <DataGrid x:Name="dgRecentProducts"
                              Margin="16,0,16,0"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              MaxHeight="240">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="1.2*" />
                            <DataGridTextColumn Header="NOMBRE" Binding="{Binding Name}" Width="2.2*" />
                            <DataGridTextColumn Header="CATEGORÍA" Binding="{Binding Category}" Width="1.5*" />
                            <DataGridTextColumn Header="STOCK" Binding="{Binding StockDisplay}" Width="1.2*" />
                            <DataGridTextColumn Header="PRECIO" Binding="{Binding UnitPriceDisplay}" Width="1*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <DockPanel Margin="16,10,16,0">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Métricas y datos listos para cotización inmediata"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <Button DockPanel.Dock="Right" Content="Ver inventario completo"
                                Style="{StaticResource GhostButton}" Click="OpenInventory_Click" />
                    </DockPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
