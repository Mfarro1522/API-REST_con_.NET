<UserControl x:Class="MakriFormas.Views.ProformaHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="{StaticResource TropicalPinkTintBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1" Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="REGISTRO DE COTIZACIONES" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <TextBlock Text="Historial de Proformas" FontSize="30" FontWeight="Black" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Height="38" CornerRadius="19" Background="White"
                            BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1"
                            Padding="12,0" Margin="0,0,10,0">
                        <Grid>
                            <TextBlock x:Name="txtSearchPlaceholder"
                                       Text="🔍  Buscar por código, cliente o RUC..."
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12" IsHitTestVisible="False" />
                            <TextBox x:Name="txtHistorySearch" Width="300"
                                     BorderThickness="0" Background="Transparent"
                                     VerticalContentAlignment="Center"
                                     Foreground="{StaticResource TextMainBrush}"
                                     TextChanged="HistorySearch_TextChanged" />
                        </Grid>
                    </Border>
                    <Button Content="🔄  Actualizar" Margin="0,0,8,0" Click="Refresh_Click" />
                    <Button Content="📝  Nueva Proforma"
                            Style="{StaticResource PrimaryButton}"
                            Click="OpenNewProforma_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Split: DataGrid + Detail panel -->
        <Grid Grid.Row="1" Margin="22,16,22,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="colDetail" Width="0" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="dgProformaHistory"
                      Grid.Column="0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      SelectionChanged="ProformaHistory_SelectionChanged"
                      MouseDoubleClick="ProformaHistory_DoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CÓDIGO" Binding="{Binding Code}" Width="1.2*" />
                    <DataGridTextColumn Header="EMISIÓN" Binding="{Binding IssueDateDisplay}" Width="1*" />
                    <DataGridTextColumn Header="CLIENTE" Binding="{Binding ClientName}" Width="2.2*" />
                    <DataGridTextColumn Header="RUC / DNI" Binding="{Binding Ruc}" Width="1.5*" />
                    <DataGridTextColumn Header="ENTREGA" Binding="{Binding DeliveryDateDisplay}" Width="1*" />
                    <DataGridTextColumn Header="ÍTEMS" Binding="{Binding ItemCount}" Width="0.8*" />
                    <DataGridTextColumn Header="TOTAL" Binding="{Binding TotalDisplay}" Width="1*" />
                    <DataGridTemplateColumn Header="ACCIONES" Width="1.5*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑 Eliminar"
                                        Style="{StaticResource DangerButton}"
                                        Padding="6,3" Margin="2"
                                        Click="DeleteProforma_Click" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Detail panel (slides in) -->
            <Border x:Name="borderDetail"
                    Grid.Column="1"
                    Background="{StaticResource TropicalYellowTintBrush}"
                    BorderBrush="{StaticResource BorderSoftBrush}"
                    BorderThickness="1,0,0,0"
                    Margin="10,0,0,0"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="18,16">
                        <DockPanel Margin="0,0,0,14">
                            <TextBlock DockPanel.Dock="Left" Text="Detalle de Proforma"
                                       FontSize="17" FontWeight="Black" />
                            <Button DockPanel.Dock="Right" Content="✕"
                                    Style="{StaticResource GhostButton}"
                                    Click="CloseDetail_Click" HorizontalAlignment="Right" />
                        </DockPanel>

                        <Border Background="{StaticResource BrandBrush}" CornerRadius="8"
                                Padding="12,8" Margin="0,0,0,14">
                            <TextBlock x:Name="txtDetailCode" Text="PF-0000-0000"
                                       FontSize="18" FontWeight="Black" Foreground="White" />
                        </Border>

                        <TextBlock Text="CLIENTE" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="txtDetailClient" Text="-" FontSize="14"
                                   FontWeight="SemiBold" Margin="0,2,0,10" />

                        <TextBlock Text="RUC / DNI" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="txtDetailRuc" Text="-" FontSize="13" Margin="0,2,0,10" />

                        <TextBlock Text="DIRECCIÓN" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="txtDetailAddress" Text="-" FontSize="13"
                                   Margin="0,2,0,10" TextWrapping="Wrap" />

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="EMISIÓN" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock x:Name="txtDetailIssueDate" Text="-" FontSize="13" Margin="0,2,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="ENTREGA" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock x:Name="txtDetailDeliveryDate" Text="-" FontSize="13" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="ÍTEMS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6" />
                        <ItemsControl x:Name="icDetailItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="6" Padding="10,8"
                                            Margin="0,0,0,4" BorderBrush="{StaticResource BorderSoftBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Description}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="Cant: {0}  |  P.Unit: S/ {1:N2}">
                                                            <Binding Path="Quantity" />
                                                            <Binding Path="UnitPrice" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Total, StringFormat=S/ {0:N2}}"
                                                       FontWeight="Bold" VerticalAlignment="Center"
                                                       Foreground="{StaticResource BrandBrush}" FontSize="13" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel x:Name="panelDesignerObs" Margin="0,12,0,0" Visibility="Collapsed">
                            <TextBlock Text="OBSERV. DISEÑADOR" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="txtDetailDesigner" TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>

                        <StackPanel x:Name="panelInstallerObs" Margin="0,8,0,0" Visibility="Collapsed">
                            <TextBlock Text="OBSERV. INSTALADOR" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="txtDetailInstaller" TextWrapping="Wrap" Margin="0,2,0,0" />
                        </StackPanel>

                        <Border Background="{StaticResource TropicalPinkTintBrush}" CornerRadius="10"
                                Padding="14" Margin="0,16,0,0"
                                BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="TOTAL COTIZACIÓN" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <TextBlock x:Name="txtDetailTotal" Text="S/ 0.00"
                                           FontSize="26" FontWeight="Black"
                                           Foreground="{StaticResource BrandBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <WrapPanel Margin="0,14,0,0">
                            <Button Content="👁️ Previsualizar"
                                    Margin="0,0,10,10" Padding="12,10"
                                    Click="PreviewSelectedPdf_Click" />

                            <Button Content="📄  Exportar a PDF"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,0,10" Padding="16,10"
                                    Click="ExportSelectedPdf_Click" />
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="2" Margin="22,8,22,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="txtHistorySummary"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource TextMutedBrush}"
                       Text="Mostrando 0 proforma(s)" />
        </Grid>
    </Grid>
</UserControl>
