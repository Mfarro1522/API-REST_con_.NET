<UserControl x:Class="MakriFormas.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="{StaticResource TropicalPinkTintBrush}" />
            <Setter Property="Padding" Value="16" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top bar: search + actions -->
        <Border Grid.Row="0" Background="{StaticResource TropicalPinkTintBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1" Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Height="38" VerticalAlignment="Center" CornerRadius="19"
                        Background="White" BorderBrush="{StaticResource BorderSoftBrush}"
                        BorderThickness="1" Padding="12,0" Width="340" HorizontalAlignment="Left">
                    <Grid>
                        <TextBlock x:Name="txtSearchPlaceholder"
                                   Text="🔍  Buscar por SKU, nombre o categoría..."
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12" IsHitTestVisible="False" />
                        <TextBox x:Name="txtInventorySearch"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalContentAlignment="Center"
                                 Foreground="{StaticResource TextMainBrush}"
                                 TextChanged="InventorySearch_TextChanged" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📥  Importar BD" Margin="0,0,8,0"
                            Style="{StaticResource GhostButton}" Click="ImportDatabase_Click" />
                    <Button Content="📤  Exportar BD"
                            Style="{StaticResource GhostButton}" Click="ExportDatabase_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main scrollable area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24">

                <!-- Title + Add button -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="LOGÍSTICA Y SUMINISTROS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock Text="Gestión de Inventario" FontSize="36" FontWeight="Black" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="➕  Añadir Producto"
                            Style="{StaticResource PrimaryButton}"
                            VerticalAlignment="Bottom"
                            Click="AddProduct_Click" />
                </Grid>

                <!-- KPI Cards -->
                <UniformGrid Columns="4" Margin="0,0,0,16">
                    <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="PRODUCTOS" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="txtActiveProducts" Text="0" FontSize="30" FontWeight="Black" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource KpiCard}" Margin="4,0">
                        <StackPanel>
                            <TextBlock Text="STOCK TOTAL" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="txtTotalStock" Text="0" FontSize="30" FontWeight="Black" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource KpiCard}" Margin="4,0">
                        <StackPanel>
                            <TextBlock Text="CATEGORÍAS" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="txtCategories" Text="0" FontSize="30" FontWeight="Black" />
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource BrandDarkBrush}" CornerRadius="14"
                            Padding="14" Margin="8,0,0,0">
                        <StackPanel>
                            <TextBlock Text="ALERTA STOCK" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TropicalYellowBrush}" />
                            <TextBlock x:Name="txtLowStock" Text="0 ítems" FontSize="30"
                                       FontWeight="Black" Foreground="White" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Products table -->
                <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                    <StackPanel>
                        <Grid Margin="16,12,16,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Listado de productos" FontWeight="Bold"
                                       Foreground="{StaticResource BrandDarkBrush}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="btnFilterLowStock"
                                        Content="⚠️  Filtrar Stock Bajo"
                                        Height="30" Margin="0,0,8,0" Padding="10,0"
                                        Background="White"
                                        Foreground="{StaticResource BrandDarkBrush}"
                                        BorderBrush="{StaticResource BrandDarkBrush}"
                                        Click="FilterLowStock_Click" />
                                <Button x:Name="btnToggleSort"
                                        Content="🔤  Ordenar A-Z"
                                        Height="30" Padding="10,0"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="ToggleSort_Click" />
                            </StackPanel>
                        </Grid>

                        <DataGrid x:Name="dgProducts"
                                  Margin="16,0,16,12"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="1.2*" />
                                <DataGridTextColumn Header="NOMBRE / ESPECIFICACIÓN" Binding="{Binding Name}" Width="3.5*" />
                                <DataGridTextColumn Header="CATEGORÍA" Binding="{Binding Category}" Width="2*" />
                                <DataGridTextColumn Header="STOCK" Binding="{Binding StockDisplay}" Width="1.5*" />
                                <DataGridTextColumn Header="PRECIO" Binding="{Binding UnitPriceDisplay}" Width="1.5*" />
                                <DataGridTemplateColumn Header="ACCIONES" Width="1.5*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑 Eliminar"
                                                    Style="{StaticResource DangerButton}"
                                                    Padding="6,3" Margin="2"
                                                    Click="DeleteProduct_Click" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock x:Name="txtProductsSummary"
                                   Margin="16,0,16,12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="Mostrando 0 productos" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
