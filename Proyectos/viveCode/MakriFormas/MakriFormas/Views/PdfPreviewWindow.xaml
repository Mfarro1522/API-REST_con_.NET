<Window x:Class="MakriFormas.Views.PdfPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Previsualización de Documento" Height="850" Width="650"
        WindowStartupLocation="CenterOwner"
        Icon="/makriLogo.ico">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Cabecera -->
        <Border Background="White" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1" Padding="20">
            <StackPanel>
                <TextBlock Text="Previsualización de PDF" FontSize="20" FontWeight="Black"/>
                <TextBlock Text="Así es como se verá el documento al exportar o imprimir." FontSize="13" Foreground="{StaticResource TextMutedBrush}"/>
            </StackPanel>
        </Border>

        <!-- Visor de PDF (renderizado nativo) -->
        <Border Grid.Row="1" Background="#F3F4F6">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" PanningMode="Both">
                <ItemsControl x:Name="icPages" HorizontalAlignment="Center" Margin="20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" Margin="0,0,0,20" Padding="0"
                                    BorderBrush="#E5E7EB" BorderThickness="1">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.1" ShadowDepth="2" BlurRadius="6" Direction="270"/>
                                </Border.Effect>
                                <Image Source="{Binding}" Stretch="Uniform" MaxWidth="600"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border x:Name="loadingOverlay" Grid.Row="1" Background="#80FFFFFF" Visibility="Visible">
            <TextBlock x:Name="txtLoading" Text="Generando vista previa..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
        </Border>

        <!-- Botones de Acción -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0" Padding="20,15">
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="Cerrar" Padding="20,10" Click="Close_Click"/>
                <Button DockPanel.Dock="Right" x:Name="btnExport" Content="Exportar PDF" Style="{StaticResource PrimaryButton}" Padding="30,10" HorizontalAlignment="Right" Click="Export_Click"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
