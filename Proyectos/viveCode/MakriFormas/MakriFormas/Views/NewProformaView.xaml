<UserControl x:Class="MakriFormas.Views.NewProformaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="TextBox">
            <EventSetter Event="GotKeyboardFocus" Handler="InputTextBox_GotKeyboardFocus" />
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="InputTextBox_PreviewMouseLeftButtonDown" />
        </Style>
    </UserControl.Resources>

    <Grid PreviewKeyDown="Root_PreviewKeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="{StaticResource TropicalYellowTintBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1" Padding="28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="NUEVA COTIZACIÓN" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextMutedBrush}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="txtProformaCode" Text="PF-0000-0000"
                                   FontSize="30" FontWeight="Black" />
                        <Border x:Name="badgeSaved" Background="#E6F9F6" CornerRadius="6"
                                Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <TextBlock Text="✔ Guardada" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}" />
                        </Border>
                        <Border x:Name="badgeUnsaved" Background="#FFF3CD" CornerRadius="6"
                                Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <TextBlock Text="● Sin guardar" FontSize="10" FontWeight="Bold"
                                       Foreground="#9A6700" />
                        </Border>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessBrush}" Margin="0,0,6,0" />
                    <TextBlock Text="Base de datos local conectada"
                               Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,20,28,20">

                <!-- CLIENT DATA -->
                <Border Background="White" CornerRadius="12" BorderBrush="#EEE"
                        BorderThickness="1" Padding="20" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Datos del Cliente" FontSize="18" FontWeight="Bold" Margin="0,0,0,14" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,8,10">
                                <TextBlock Text="NOMBRE / RAZÓN SOCIAL" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                                <TextBox x:Name="txtCliente" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="RUC / DNI" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                                <TextBox x:Name="txtRuc" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2">
                                <TextBlock Text="DIRECCIÓN DE ENTREGA" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                                <TextBox x:Name="txtDireccion" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- PRODUCT SELECTION -->
                <Border Background="White" CornerRadius="12" BorderBrush="#EEE"
                        BorderThickness="1" Padding="20" Margin="0,0,0,14">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <TextBlock DockPanel.Dock="Left" Text="Ítems de la Proforma"
                                       FontSize="18" FontWeight="Bold" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <TextBlock x:Name="txtItemCount" Text="0 ítem(s)"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,14,0" />
                                <Button Content="Limpiar" Padding="10,6" Margin="0,0,8,0"
                                        Click="ClearItems_Click" />
                                <Button Content="Registrar faltante" Padding="10,6" Margin="0,0,8,0"
                                        Click="RegisterMissingProduct_Click" />
                                <Button Content="+ Añadir Ítem" Padding="10,6"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="AddProduct_Click" />
                            </StackPanel>
                        </DockPanel>

                        <!-- Search bar -->
                        <DockPanel Margin="0,0,0,10">
                            <Button DockPanel.Dock="Right"
                                    Content="Agregar 1er resultado"
                                    Padding="10,6"
                                    Margin="8,0,0,0"
                                    Click="AddTopSearchResult_Click" />
                            <Border Background="#F3F3F3" CornerRadius="8" Padding="10">
                                <Grid>
                                    <TextBlock x:Name="txtCatalogSearchPlaceholder"
                                               Text="🔍  Buscar producto por SKU, nombre o categoría..."
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" IsHitTestVisible="False" />
                                    <TextBox x:Name="txtCatalogSearch"
                                             BorderThickness="0" Background="Transparent"
                                             VerticalContentAlignment="Center"
                                             TextChanged="CatalogSearch_TextChanged"
                                             KeyDown="CatalogSearch_KeyDown" />
                                </Grid>
                            </Border>
                        </DockPanel>

                        <TextBlock x:Name="txtCatalogNoResults"
                                   Text="No hay coincidencias. Puedes registrar este producto con 'Registrar faltante'."
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Visibility="Collapsed" Margin="0,0,0,8" TextWrapping="Wrap" />

                        <ListBox x:Name="lbProductMatches"
                                 MaxHeight="130" Margin="0,0,0,14"
                                 SelectionChanged="ProductMatches_SelectionChanged"
                                 BorderBrush="#E0E0E0" BorderThickness="1" Background="#FCFCFC">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Sku}" FontWeight="Bold"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="8,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding UnitPriceDisplay}"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{StaticResource BrandBrush}"
                                                   FontWeight="Bold" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Column headers for item rows -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Descripción" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock Grid.Column="1" Text="Unidad" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="Dimensiones" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="Cant" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="P. Unitario" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" />
                            <TextBlock Grid.Column="5" Text="Total" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" />
                        </Grid>

                        <!-- Items list -->
                        <ItemsControl x:Name="icItems">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F8F8" CornerRadius="8"
                                            Padding="10,8" Margin="0,0,0,6"
                                            BorderBrush="#EBEBEB" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="60" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="34" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Descripción -->
                                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                     FontWeight="Bold" BorderThickness="0"
                                                     Background="Transparent" VerticalAlignment="Center" />

                                            <!-- Unidad -->
                                            <ComboBox Grid.Column="1"
                                                      SelectedValue="{Binding Unidad, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Tag"
                                                      VerticalAlignment="Center" FontSize="11"
                                                      SelectionChanged="ItemUnidad_SelectionChanged">
                                                <ComboBoxItem Tag="unidad" Content="und" />
                                                <ComboBoxItem Tag="kg" Content="kg" />
                                                <ComboBoxItem Tag="millares" Content="millares" />
                                                <ComboBoxItem Tag="cientos" Content="cientos" />
                                                <ComboBoxItem Tag="m2" Content="m²" />
                                                <ComboBoxItem Tag="metro" Content="metro" />
                                                <ComboBoxItem Tag="cm" Content="cm" />
                                                <ComboBoxItem Tag="cm2" Content="cm²" />
                                            </ComboBox>

                                            <!-- Dimensiones dinámicas -->
                                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                            Visibility="{Binding IsAreaBased, Converter={StaticResource BoolToVisible}}">
                                                    <TextBox Width="36" Text="{Binding Ancho, UpdateSourceTrigger=LostFocus}"
                                                             TextAlignment="Center" BorderThickness="1" BorderBrush="#DDD" />
                                                    <TextBlock Text=" × " VerticalAlignment="Center" FontSize="11" />
                                                    <TextBox Width="36" Text="{Binding Alto, UpdateSourceTrigger=LostFocus}"
                                                             TextAlignment="Center" BorderThickness="1" BorderBrush="#DDD" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                            Visibility="{Binding IsMetro, Converter={StaticResource BoolToVisible}}">
                                                    <TextBox Width="58" Text="{Binding Longitud, UpdateSourceTrigger=LostFocus}"
                                                             TextAlignment="Center" BorderThickness="1" BorderBrush="#DDD" />
                                                    <TextBlock Text=" m" VerticalAlignment="Center" FontSize="11" />
                                                </StackPanel>
                                                <TextBlock Text="—" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="#CCC"
                                                           Visibility="{Binding IsSimpleUnit, Converter={StaticResource BoolToVisible}}" />
                                            </Grid>

                                            <!-- Cantidad -->
                                            <TextBox Grid.Column="3" Width="46" HorizontalAlignment="Center"
                                                     TextAlignment="Center" VerticalAlignment="Center"
                                                     Text="{Binding Cantidad, UpdateSourceTrigger=LostFocus}"
                                                     BorderThickness="1" BorderBrush="#DDD" />

                                            <!-- Precio unitario -->
                                            <TextBox Grid.Column="4" Width="70" HorizontalAlignment="Right"
                                                     TextAlignment="Right" VerticalAlignment="Center"
                                                     Text="{Binding UnitPrice, UpdateSourceTrigger=LostFocus}"
                                                     BorderThickness="1" BorderBrush="#DDD" />

                                            <!-- Total -->
                                            <TextBlock Grid.Column="5"
                                                       Text="{Binding Total, StringFormat=S/ {0:N2}}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       FontWeight="Bold" />

                                                <Button Grid.Column="6" Content="⎘"
                                                    Width="26" Height="26"
                                                    VerticalAlignment="Center"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="{StaticResource TextMutedBrush}"
                                                    FontWeight="Bold"
                                                    Cursor="Hand"
                                                    Click="DuplicateItem_Click"
                                                    ToolTip="Duplicar ítem" />

                                                <!-- Delete button -->
                                                <Button Grid.Column="7" Content="✕"
                                                    Width="26" Height="26"
                                                    VerticalAlignment="Center"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    FontWeight="Bold"
                                                    Cursor="Hand"
                                                    Click="DeleteItem_Click"
                                                    ToolTip="Eliminar ítem" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border x:Name="emptyItemsState"
                                Background="#FFFAEE"
                                BorderBrush="#F6DE95"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                Visibility="Collapsed">
                            <DockPanel>
                                <TextBlock Text="Todavía no hay ítems. Usa el catálogo o agrega uno manualmente para empezar."
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMutedBrush}" />
                                <Button DockPanel.Dock="Right"
                                        Content="Crear primer ítem"
                                        Margin="12,0,0,0"
                                        Padding="10,6"
                                        Click="AddProduct_Click" />
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- DESIGN PARAMS -->
                <Border Background="White" CornerRadius="12" BorderBrush="#EEE"
                        BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Parámetros de diseño e instalación"
                                   FontSize="18" FontWeight="Bold" Margin="0,0,0,14" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.ColumnSpan="2" Margin="0,0,0,10">
                                <TextBlock Text="Editor de observaciones" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                                <WrapPanel>
                                    <ComboBox x:Name="cmbObservationFontFamily"
                                              Width="170"
                                              Margin="0,0,8,0"
                                              SelectionChanged="ObservationFontFamily_SelectionChanged" />
                                    <ToggleButton x:Name="btnObsBold" Content="B" FontWeight="Bold"
                                                  Width="34" Height="28" Margin="0,0,6,0"
                                                  Click="ToggleBold_Click" />
                                    <ToggleButton x:Name="btnObsItalic" Content="I" FontStyle="Italic"
                                                  Width="34" Height="28" Margin="0,0,6,0"
                                                  Click="ToggleItalic_Click" />
                                    <ToggleButton x:Name="btnObsUnderline" Content="U"
                                                  Width="34" Height="28"
                                                  Click="ToggleUnderline_Click" />
                                </WrapPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,8,10">
                                <TextBlock Text="FECHA DE ENTREGA" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                                <DatePicker x:Name="dpFecha" Width="160" HorizontalAlignment="Left" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,10">
                                <TextBlock Text="OBSERVACIONES DEL DISEÑADOR" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                                <RichTextBox x:Name="rtbDesignerObservations"
                                             Height="96"
                                             VerticalScrollBarVisibility="Auto"
                                             GotFocus="ObservationRichTextBox_GotFocus"
                                             SelectionChanged="ObservationRichTextBox_SelectionChanged" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                <TextBlock Text="OBSERVACIONES DEL INSTALADOR" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4" />
                                <RichTextBox x:Name="rtbInstallerObservations"
                                             Height="110"
                                             VerticalScrollBarVisibility="Auto"
                                             GotFocus="ObservationRichTextBox_GotFocus"
                                             SelectionChanged="ObservationRichTextBox_SelectionChanged" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer / Actions bar -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="0,1,0,0" Padding="28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Total Cotización:" FontSize="15" FontWeight="Bold" Margin="0,0,10,0" />
                    <TextBlock x:Name="txtOverallTotal" Text="S/ 0.00"
                               FontSize="26" FontWeight="Black"
                               Foreground="{StaticResource BrandBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnSave" Content="💾  Guardar" Padding="16,9"
                            Margin="0,0,10,0" Click="SaveProforma_Click" />
                    <Button x:Name="btnSaveAndNew" Content="⚡  Guardar y nueva" Padding="16,9"
                        Margin="0,0,10,0" Click="SaveAndNew_Click" />
                    <Button x:Name="btnReset" Content="Limpiar" Padding="16,9"
                        Margin="0,0,10,0" Click="ResetForm_Click" />
                    <Button x:Name="btnExport" Content="📄  Exportar PDF" Padding="16,9"
                            Style="{StaticResource PrimaryButton}"
                            Click="ExportPdf_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
