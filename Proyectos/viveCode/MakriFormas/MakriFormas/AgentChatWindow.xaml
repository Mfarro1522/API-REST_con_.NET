<Window x:Class="MakriFormas.AgentChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🤖 Asistente MakriFormas" Height="680" Width="520"
        MinHeight="500" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="16">
        <Border CornerRadius="16" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="{StaticResource TropicalPinkTintBrush}"
                        BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1"
                        CornerRadius="16,16,0,0" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="🤖 Asistente IA" FontSize="20" FontWeight="Black" />
                            <TextBlock x:Name="txtModelInfo" Text="Cargando..." FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="elAiStatus" Width="10" Height="10"
                                     Fill="#CCCCCC" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtAiStatus" Text="Comprobando..."
                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Chat messages -->
                <ScrollViewer Grid.Row="1" x:Name="scrollChat"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="12,10">
                    <ItemsControl x:Name="icMessages">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <!-- Usuario: burbuja derecha (azul) -->
                                    <Border HorizontalAlignment="Right"
                                            Background="#069494" CornerRadius="14,14,2,14"
                                            Padding="12,8" MaxWidth="340"
                                            Visibility="{Binding IsUser, Converter={StaticResource BoolToVisible}}">
                                        <TextBlock Text="{Binding Content}" Foreground="White"
                                                   TextWrapping="Wrap" FontSize="13" />
                                    </Border>
                                    <!-- Agente: burbuja izquierda (gris) -->
                                    <Border HorizontalAlignment="Left"
                                            Background="#F0F0F0" CornerRadius="14,14,14,2"
                                            Padding="12,8" MaxWidth="360"
                                            Visibility="{Binding IsAgent, Converter={StaticResource BoolToVisible}}">
                                        <TextBlock Text="{Binding Content}" Foreground="#1B1E1F"
                                                   TextWrapping="Wrap" FontSize="13" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Thinking indicator -->
                <Border Grid.Row="2" x:Name="pnlThinking" Visibility="Collapsed"
                        Padding="16,6" Background="{StaticResource TropicalYellowTintBrush}"
                        BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="txtThinking" Text="⏳ Pensando..."
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               FontStyle="Italic" />
                </Border>

                <!-- Input area -->
                <Border Grid.Row="3" BorderBrush="{StaticResource BorderSoftBrush}"
                        BorderThickness="0,1,0,0" Padding="12,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" Margin="2,0,2,6">
                                <TextBlock x:Name="txtAttachment"
                                           Text=""
                                           Visibility="Collapsed"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           VerticalAlignment="Center" />
                                <Button x:Name="btnClearAttachment"
                                        Content="Quitar"
                                        Visibility="Collapsed"
                                        DockPanel.Dock="Right"
                                        Padding="6,2"
                                        FontSize="11"
                                        Margin="8,0,0,0"
                                        Click="ClearAttachment_Click" />
                            </DockPanel>

                            <Border Grid.Row="1" CornerRadius="10" BorderBrush="{StaticResource BorderSoftBrush}"
                                    BorderThickness="1" Background="White">
                                <Grid>
                                    <TextBlock x:Name="txtInputPlaceholder"
                                               Text="Escribe un mensaje... (Enter para enviar)"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="13" Margin="11,9,0,0"
                                               IsHitTestVisible="False"
                                               VerticalAlignment="Top" />
                                    <TextBox x:Name="txtInput"
                                             Padding="10,8"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="False"
                                             MaxHeight="80"
                                             VerticalScrollBarVisibility="Auto"
                                             FontSize="13"
                                             KeyDown="TxtInput_KeyDown"
                                             TextChanged="TxtInput_TextChanged" />
                                </Grid>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="8,0,0,0">
                            <Button x:Name="btnAttach"
                                    Content="📎"
                                    Width="42" Height="38"
                                    FontSize="15"
                                    Margin="0,0,8,0"
                                    Click="AttachFile_Click" />
                            <Button x:Name="btnSend"
                                    Content="➤" Width="42" Height="38"
                                    FontSize="16"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnSend_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
