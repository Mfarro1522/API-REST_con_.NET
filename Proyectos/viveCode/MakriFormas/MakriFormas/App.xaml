<Application x:Class="MakriFormas.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MakriFormas"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisible" />

        <!-- ── Color tokens ── -->
        <Color x:Key="ColorBrand">#069494</Color>
        <Color x:Key="ColorBrandDark">#FF8243</Color>
        <Color x:Key="ColorSurface">#FFFEFB</Color>
        <Color x:Key="ColorSurfaceAlt">#FFF8FB</Color>
        <Color x:Key="ColorBorder">#FFC0CB</Color>
        <Color x:Key="ColorText">#1B1E1F</Color>
        <Color x:Key="ColorMuted">#4F5C60</Color>
        <Color x:Key="ColorSuccess">#069494</Color>
        <Color x:Key="ColorDanger">#DC3545</Color>

        <!-- ── Brushes ── -->
        <SolidColorBrush x:Key="TropicalOrangeBrush"     Color="#FF8243" />
        <SolidColorBrush x:Key="TropicalPinkBrush"       Color="#FFC0CB" />
        <SolidColorBrush x:Key="TropicalYellowBrush"     Color="#FCE883" />
        <SolidColorBrush x:Key="TropicalTealBrush"       Color="#069494" />
        <SolidColorBrush x:Key="TropicalPinkTintBrush"   Color="#FFF3F6" />
        <SolidColorBrush x:Key="TropicalYellowTintBrush" Color="#FFFCDF" />

        <SolidColorBrush x:Key="BrandBrush"      Color="{StaticResource ColorBrand}" />
        <SolidColorBrush x:Key="BrandDarkBrush"  Color="{StaticResource ColorBrandDark}" />
        <SolidColorBrush x:Key="SurfaceBrush"    Color="{StaticResource ColorSurface}" />
        <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource ColorSurfaceAlt}" />
        <SolidColorBrush x:Key="BorderSoftBrush" Color="{StaticResource ColorBorder}" />
        <SolidColorBrush x:Key="TextMainBrush"   Color="{StaticResource ColorText}" />
        <SolidColorBrush x:Key="TextMutedBrush"  Color="{StaticResource ColorMuted}" />
        <SolidColorBrush x:Key="SuccessBrush"    Color="{StaticResource ColorSuccess}" />
        <SolidColorBrush x:Key="DangerBrush"     Color="{StaticResource ColorDanger}" />

        <!-- Gradient backgrounds -->
        <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFF4" Offset="0" />
            <GradientStop Color="#FFF7E9" Offset="0.45" />
            <GradientStop Color="#FFF2F6" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SidebarBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#1B2B2B" Offset="0" />
            <GradientStop Color="#1E3232" Offset="1" />
        </LinearGradientBrush>

        <!-- ════════════ GLOBAL TYPE STYLES ════════════ -->

        <Style TargetType="Window">
            <Setter Property="Icon"       Value="makriLogo.ico" />
            <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}" />
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
        </Style>

        <!-- Global TextBlock: dark text for light surfaces -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
        </Style>

        <!-- ════════════ CARD ════════════ -->
        <Style TargetType="Border" x:Key="CardBorderStyle">
            <Setter Property="Background"      Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="14" />
            <Setter Property="Padding"         Value="16" />
        </Style>

        <!-- ════════════ BASE BUTTON ════════════
             KEY FIX: ControlTemplate.Resources overrides the global TextBlock style
             INSIDE the button scope so that Foreground propagates correctly.
             Triggers change Button.Foreground; the binding picks it up reactively.
        ═════════════════════════════════════════════ -->
        <Style TargetType="Button">
            <Setter Property="Padding"         Value="14,8" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Foreground"      Value="{StaticResource TextMainBrush}" />
            <Setter Property="Background"      Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ControlTemplate.Resources>
                            <!-- Override global TextBlock style: bind to Button.Foreground -->
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                            </Style>
                            <Style TargetType="AccessText">
                                <Setter Property="Foreground"
                                        Value="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                            </Style>
                        </ControlTemplate.Resources>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary: teal fill, white text -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="{StaticResource BrandBrush}" />
            <Setter Property="Foreground"  Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BrandBrush}" />
        </Style>

        <!-- Ghost: no border, muted text -->
        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground"  Value="{StaticResource TextMutedBrush}" />
            <Setter Property="Padding"     Value="10,6" />
        </Style>

        <!-- Danger: light red fill, red text -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"  Value="#FFEEEE" />
            <Setter Property="Foreground"  Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="#FFCCCC" />
            <Setter Property="Padding"     Value="8,4" />
        </Style>

        <!-- ════════════ SIDEBAR NAV BUTTONS ════════════
             Custom templates — ControlTemplate.Resources TextBlock style fix applied.
             Hover trigger sets Button.Foreground = White; binding cascades.
        ═══════════════════════════════════════════════════ -->

        <!-- Normal sidebar item -->
        <Style x:Key="NavItem" TargetType="Button">
            <Setter Property="Background"                 Value="Transparent" />
            <Setter Property="BorderThickness"            Value="0" />
            <Setter Property="Foreground"                 Value="#B8D4D4" />
            <Setter Property="FontWeight"                 Value="SemiBold" />
            <Setter Property="FontSize"                   Value="13" />
            <Setter Property="Padding"                    Value="14,11" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor"                     Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ControlTemplate.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                            </Style>
                            <Style TargetType="AccessText">
                                <Setter Property="Foreground"
                                        Value="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                            </Style>
                        </ControlTemplate.Resources>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A4848" />
                                <Setter Property="Foreground"                 Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A3030" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active sidebar item: teal bg, white text, yellow left bar -->
        <Style x:Key="NavItemActive" TargetType="Button">
            <Setter Property="Background"                 Value="#2E5C5C" />
            <Setter Property="BorderThickness"            Value="0" />
            <Setter Property="Foreground"                 Value="White" />
            <Setter Property="FontWeight"                 Value="SemiBold" />
            <Setter Property="FontSize"                   Value="13" />
            <Setter Property="Padding"                    Value="14,11" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor"                     Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ControlTemplate.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground"
                                        Value="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                            </Style>
                            <Style TargetType="AccessText">
                                <Setter Property="Foreground"
                                        Value="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                            </Style>
                        </ControlTemplate.Resources>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <!-- Yellow accent bar -->
                                <Border Width="3" Background="#FCE883"
                                        HorizontalAlignment="Left"
                                        CornerRadius="2" Margin="-2,4" />
                                <ContentPresenter Margin="8,0,0,0"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    TextElement.Foreground="{TemplateBinding Foreground}"
                                    VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#356A6A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ════════════ INPUTS ════════════ -->

        <Style TargetType="TextBox">
            <Setter Property="Padding"         Value="10,7" />
            <Setter Property="Background"      Value="White" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground"      Value="{StaticResource TextMainBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding"         Value="8,5" />
            <Setter Property="Background"      Value="White" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Background"      Value="White" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- ════════════ DATA GRID ════════════ -->

        <Style TargetType="DataGrid">
            <Setter Property="RowBackground"            Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#FFF7FB" />
            <Setter Property="BorderBrush"              Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness"          Value="1" />
            <Setter Property="GridLinesVisibility"      Value="Horizontal" />
            <Setter Property="HeadersVisibility"        Value="Column" />
            <Setter Property="HorizontalGridLinesBrush" Value="#FFE1E8" />
            <Setter Property="VerticalGridLinesBrush"   Value="#FFE1E8" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{StaticResource SurfaceAltBrush}" />
            <Setter Property="Foreground"      Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontWeight"      Value="Bold" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Padding"         Value="12,10" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <!-- Watermark TextBox (transparent overlay for search fields) -->
        <Style x:Key="WatermarkTextBox" TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Padding"                  Value="10,7" />
            <Setter Property="Background"               Value="Transparent" />
            <Setter Property="BorderThickness"          Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground"               Value="{StaticResource TextMainBrush}" />
        </Style>

    </Application.Resources>
</Application>
