<Window x:Class="MakriFormas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MakriFormas"
        mc:Ignorable="d"
        Title="Makricolors Publicidad" Height="820" Width="1280" MinHeight="720" MinWidth="1100"
        WindowState="Maximized">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="colChatDrawer" Width="0" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════ SIDEBAR ══════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0" Padding="18,20,18,16"
                        BorderBrush="#2A4040" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="makriLogo.ico" Width="32" Height="32"
                               Margin="0,0,10,0" VerticalAlignment="Center" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="MAKRICOLORS" FontSize="13" FontWeight="Black"
                                       Foreground="White" />
                            <TextBlock Text="Sistema Comercial" FontSize="10" Foreground="#6A9A9A" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10,16,10,8">

                        <TextBlock Text="MÓDULOS" FontSize="9" FontWeight="Bold"
                                   Foreground="#4A7070" Margin="6,0,0,6" />

                        <Button x:Name="btnNavDashboard"
                                Style="{StaticResource NavItemActive}"
                                Click="NavDashboard_Click">
                            <TextBlock Text="🏠  Dashboard"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>

                        <Button x:Name="btnNavNewProforma"
                                Style="{StaticResource NavItem}"
                                Click="NavNewProforma_Click"
                                Margin="0,2,0,0">
                            <TextBlock Text="📝  Nueva Proforma"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>

                        <Button x:Name="btnNavHistory"
                                Style="{StaticResource NavItem}"
                                Click="NavHistory_Click"
                                Margin="0,2,0,0">
                            <TextBlock Text="🗂  Historial"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>

                        <Button x:Name="btnNavInventory"
                                Style="{StaticResource NavItem}"
                                Click="NavInventory_Click"
                                Margin="0,2,0,0">
                            <TextBlock Text="📦  Inventario"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>

                        <Separator Background="#2A4040" Margin="6,14,6,14" />

                        <TextBlock Text="HERRAMIENTAS" FontSize="9" FontWeight="Bold"
                                   Foreground="#4A7070" Margin="6,0,0,6" />

                        <Button x:Name="btnNavAgent"
                                Style="{StaticResource NavItem}"
                                Click="ToggleChatDrawer_Click"
                                Margin="0,2,0,0">
                            <TextBlock Text="🤖  Asistente IA"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>

                        <Button Style="{StaticResource NavItem}"
                                Click="OpenImportPdf_Click"
                                Margin="0,2,0,0">
                            <TextBlock Text="📄  Importar Proforma"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>

                        <Button Style="{StaticResource NavItem}"
                                Click="OpenAiSettings_Click"
                                Margin="0,2,0,0">
                            <TextBlock Text="⚙️  Configuración IA"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>

                        <Separator Background="#2A4040" Margin="6,14,6,14" />

                        <TextBlock Text="BASE DE DATOS" FontSize="9" FontWeight="Bold"
                                   Foreground="#4A7070" Margin="6,0,0,6" />

                        <Button Style="{StaticResource NavItem}"
                                Click="ImportDatabase_Click"
                                Margin="0,2,0,0">
                            <TextBlock Text="📥  Importar BD"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>

                        <Button Style="{StaticResource NavItem}"
                                Click="ExportDatabase_Click"
                                Margin="0,2,0,0">
                            <TextBlock Text="📤  Exportar BD"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}" />
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- User info footer -->
                <Border Grid.Row="2" Padding="14,12"
                        BorderBrush="#2A4040" BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="30" Height="30">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#069494" />
                                    <GradientStop Color="#FCE883" Offset="1" />
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Admin" FontWeight="Bold" FontSize="12" Foreground="White" />
                            <TextBlock Text="Makricolors" FontSize="10" Foreground="#6A9A9A" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════ MAIN CONTENT ══════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top header bar -->
            <Border Grid.Row="0" Background="{StaticResource TropicalPinkTintBrush}"
                    BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1"
                    Padding="22,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="txtCurrentSection"
                                   Text="Dashboard" FontSize="20" FontWeight="Black" />
                        <TextBlock x:Name="txtCurrentSectionSub"
                                   Text="Panel principal"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnToggleChat"
                                Content="🤖  Asistente"
                                Style="{StaticResource GhostButton}"
                                Click="ToggleChatDrawer_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Section content area -->
            <ContentControl x:Name="MainContent" Grid.Row="1" />
        </Grid>

        <!-- ══════════════ AI CHAT DRAWER ══════════════ -->
        <Border Grid.Column="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}"
                BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Drawer header -->
                <Border Grid.Row="0" Background="{StaticResource TropicalPinkTintBrush}"
                        BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="🤖 Asistente IA" FontSize="16" FontWeight="Black" />
                            <TextBlock x:Name="txtModelInfo" Text="Cargando..."
                                       FontSize="9" Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="elAiStatus" Width="9" Height="9"
                                     Fill="#CCCCCC" Margin="0,0,5,0" />
                            <TextBlock x:Name="txtAiStatus" Text="Comprobando..."
                                       FontSize="9" Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Chat messages -->
                <ScrollViewer Grid.Row="1" x:Name="scrollChat"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="10,8">
                    <ItemsControl x:Name="icMessages">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Border HorizontalAlignment="Right"
                                            Background="#069494" CornerRadius="14,14,2,14"
                                            Padding="10,7" MaxWidth="280"
                                            Visibility="{Binding IsUser, Converter={StaticResource BoolToVisible}}">
                                        <TextBlock Text="{Binding Content}" Foreground="White"
                                                   TextWrapping="Wrap" FontSize="12" />
                                    </Border>
                                    <Border HorizontalAlignment="Left"
                                            Background="#F0F0F0" CornerRadius="14,14,14,2"
                                            Padding="10,7" MaxWidth="300"
                                            Visibility="{Binding IsAgent, Converter={StaticResource BoolToVisible}}">
                                        <TextBlock Text="{Binding Content}" Foreground="#1B1E1F"
                                                   TextWrapping="Wrap" FontSize="12" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Thinking indicator -->
                <Border Grid.Row="2" x:Name="pnlThinking" Visibility="Collapsed"
                        Padding="14,5" Background="{StaticResource TropicalYellowTintBrush}"
                        BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="txtThinking" Text="⏳ Pensando..."
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                               FontStyle="Italic" />
                </Border>

                <!-- Chat input -->
                <Border Grid.Row="3" BorderBrush="{StaticResource BorderSoftBrush}"
                        BorderThickness="0,1,0,0" Padding="10,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Attachment indicator -->
                        <DockPanel Grid.Row="0" Margin="2,0,2,5">
                            <TextBlock x:Name="txtAttachment" Text="" Visibility="Collapsed"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="10"
                                       VerticalAlignment="Center" />
                            <Button x:Name="btnClearAttachment" Visibility="Collapsed"
                                    DockPanel.Dock="Right" Padding="4,2" Margin="6,0,0,0"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="#E74C3C" Cursor="Hand" ToolTip="Quitar archivo"
                                    Click="ClearAttachment_Click">
                                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           Text="&#xE74D;" FontSize="11" />
                            </Button>
                        </DockPanel>

                        <!-- Input row -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border CornerRadius="10" BorderBrush="{StaticResource BorderSoftBrush}"
                                    BorderThickness="1" Background="White">
                                <Grid>
                                    <TextBlock x:Name="txtInputPlaceholder"
                                               Text="Escribe... (Enter para enviar)"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12" Margin="10,8,0,0"
                                               IsHitTestVisible="False" VerticalAlignment="Top" />
                                    <TextBox x:Name="txtInput" Padding="9,7"
                                             BorderThickness="0" Background="Transparent"
                                             TextWrapping="Wrap" AcceptsReturn="False"
                                             MaxHeight="70" VerticalScrollBarVisibility="Auto"
                                             FontSize="12"
                                             KeyDown="TxtInput_KeyDown"
                                             TextChanged="TxtInput_TextChanged" />
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        VerticalAlignment="Bottom" Margin="6,0,0,0">
                                <Button x:Name="btnAttach"
                                        Content="&#xE723;"
                                        FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                        Width="36" Height="34" FontSize="14" Margin="0,0,5,0"
                                        Background="Transparent"
                                        BorderThickness="1" BorderBrush="{StaticResource BorderSoftBrush}"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Cursor="Hand" ToolTip="Adjuntar archivo"
                                        Click="AttachFile_Click" />
                                <Button x:Name="btnSend" Content="➤"
                                        Width="36" Height="34" FontSize="14"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="BtnSend_Click" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
