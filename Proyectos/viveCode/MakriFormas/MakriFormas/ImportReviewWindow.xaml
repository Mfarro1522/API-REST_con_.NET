<Window x:Class="MakriFormas.ImportReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revisión de Importación de Proforma" Height="700" Width="780"
        MinHeight="550" MinWidth="680"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="18">
        <Border CornerRadius="16" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="{StaticResource TropicalPinkTintBrush}"
                        BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1"
                        CornerRadius="16,16,0,0" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="📄 Revisión de importación" FontSize="22" FontWeight="Black" />
                        <TextBlock Text="Revisa y selecciona qué productos importar. Solo lo confirmado se guardará."
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Progress bar (visible during processing) -->
                <Border Grid.Row="1" x:Name="pnlProgress" Visibility="Collapsed"
                        Padding="18,10" Background="{StaticResource TropicalYellowTintBrush}"
                        BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock x:Name="txtProgressStatus" Text="Procesando archivo..."
                                   FontSize="12" FontWeight="Bold" Margin="0,0,0,6"/>
                        <ProgressBar x:Name="pbProgress" Height="6" IsIndeterminate="True"
                                     Foreground="{StaticResource BrandBrush}" />
                    </StackPanel>
                </Border>

                <!-- Main content -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="18,12">
                    <StackPanel x:Name="pnlContent">

                        <!-- Nuevos productos -->
                        <Border Background="White" CornerRadius="10"
                                BorderBrush="#E8E8E8" BorderThickness="1"
                                Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Ellipse Width="12" Height="12" Fill="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Nuevos productos" FontSize="16" FontWeight="Bold" />
                                    <TextBlock x:Name="txtNewCount" Text=" (0)" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                    <TextBlock Text=" — se agregarán al catálogo" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Bottom" Margin="0,0,0,1" FontSize="11"/>
                                </StackPanel>
                                <DataGrid x:Name="dgNew" AutoGenerateColumns="False"
                                          CanUserAddRows="False" MaxHeight="180"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected}" Width="36" />
                                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*" />
                                        <DataGridTextColumn Header="Precio" Binding="{Binding PrecioDisplay}" Width="90" />
                                        <DataGridTextColumn Header="Unidad" Binding="{Binding Unidad}" Width="80" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock x:Name="txtNoNew" Text="No hay productos nuevos."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontStyle="Italic" Visibility="Collapsed" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Precio cambiado -->
                        <Border Background="White" CornerRadius="10"
                                BorderBrush="#E8E8E8" BorderThickness="1"
                                Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Ellipse Width="12" Height="12" Fill="#F59E0B" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Precio actualizado" FontSize="16" FontWeight="Bold" />
                                    <TextBlock x:Name="txtChangedCount" Text=" (0)" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                    <TextBlock Text=" — actualizará el precio en inventario" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Bottom" Margin="0,0,0,1" FontSize="11"/>
                                </StackPanel>
                                <DataGrid x:Name="dgChanged" AutoGenerateColumns="False"
                                          CanUserAddRows="False" MaxHeight="180"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected}" Width="36" />
                                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*" />
                                        <DataGridTextColumn Header="Precio actual" Binding="{Binding PrecioActualDisplay}" Width="110" />
                                        <DataGridTextColumn Header="Precio nuevo" Binding="{Binding PrecioNuevoDisplay}" Width="110" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock x:Name="txtNoChanged" Text="No hay cambios de precio."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontStyle="Italic" Visibility="Collapsed" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Duplicados exactos (solo informativo) -->
                        <Border Background="#F9F9F9" CornerRadius="10"
                                BorderBrush="#E8E8E8" BorderThickness="1"
                                Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Ellipse Width="12" Height="12" Fill="#6B7280" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Ya existen (sin cambios)" FontSize="16" FontWeight="Bold" />
                                    <TextBlock x:Name="txtDupeCount" Text=" (0)" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                </StackPanel>
                                <DataGrid x:Name="dgDupes" AutoGenerateColumns="False"
                                          CanUserAddRows="False" IsReadOnly="True" MaxHeight="120"
                                          HeadersVisibility="Column" Opacity="0.65">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*" />
                                        <DataGridTextColumn Header="Precio" Binding="{Binding PrecioDisplay}" Width="90" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock x:Name="txtNoDupes" Text="No hay duplicados exactos."
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontStyle="Italic" Visibility="Collapsed" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="3" BorderBrush="{StaticResource BorderSoftBrush}"
                        BorderThickness="0,1,0,0" Padding="18,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="txtSummary" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="Cancelar" Click="Cancel_Click"
                                    Style="{StaticResource GhostButton}" Margin="0,0,8,0" />
                            <Button x:Name="btnConfirm" Content="✅  Confirmar importación"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="Confirm_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
