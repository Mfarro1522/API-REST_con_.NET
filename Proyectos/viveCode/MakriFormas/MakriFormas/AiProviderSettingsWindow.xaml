<Window x:Class="MakriFormas.AiProviderSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración IA" Height="620" Width="720"
        MinHeight="560" MinWidth="650"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">

    <Grid Margin="18">
        <Border CornerRadius="16" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource TropicalPinkTintBrush}"
                        BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1"
                        CornerRadius="16,16,0,0" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="⚙️ Configuración de IA" FontSize="22" FontWeight="Black" />
                        <TextBlock Text="Google será proveedor principal y Groq respaldo automático."
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="18,14">
                    <StackPanel>
                        <TextBlock Text="Google API Key" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                        <PasswordBox x:Name="pwdGoogleApiKey" Margin="0,6,0,2" Height="32" />
                        <TextBlock x:Name="txtGoogleStatus" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,12" />

                        <TextBlock Text="Groq API Key" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                        <PasswordBox x:Name="pwdGroqApiKey" Margin="0,6,0,2" Height="32" />
                        <TextBlock x:Name="txtGroqStatus" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,12" />

                        <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Modelos Google (económicos)" FontWeight="Bold" FontSize="14" />
                                <TextBlock Text="Usa Gemini Flash para balance de costo y calidad." Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,10" />

                                <TextBlock Text="Chat" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                <ComboBox x:Name="cmbGoogleChatModel" Margin="0,6,0,10" />

                                <TextBlock Text="Visión (importación de proformas imagen/PDF)" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                <ComboBox x:Name="cmbGoogleVisionModel" Margin="0,6,0,2" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Padding="14" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Modelo Groq (respaldo económico)" FontWeight="Bold" FontSize="14" />
                                <TextBlock Text="Se usa cuando Google falla por cuota, rate-limit o error temporal." Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,10" />

                                <TextBlock Text="Chat/Fallback" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                <ComboBox x:Name="cmbGroqChatModel" Margin="0,6,0,10" />

                                <CheckBox x:Name="chkEnableGroqFallback" Content="Activar fallback automático a Groq" IsChecked="True" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Solo se muestran modelos baratos predefinidos para evitar costos altos al cliente."
                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11" FontStyle="Italic" />
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,1,0,0" Padding="14,10">
                    <DockPanel>
                        <TextBlock x:Name="txtSaveStatus" DockPanel.Dock="Left" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="Cancelar" Margin="0,0,8,0" Click="Cancel_Click" />
                            <Button Content="Guardar configuración" Style="{StaticResource PrimaryButton}" Click="Save_Click" />
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
