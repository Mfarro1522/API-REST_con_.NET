<Window x:Class="MakriFormas.InventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gestión de Inventario - Makricolors"
        Height="840" Width="1320"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
            <Setter Property="Background" Value="{StaticResource TropicalPinkTintBrush}" />
            <Setter Property="Padding" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Border Style="{StaticResource CardBorderStyle}" Padding="0" CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource TropicalYellowTintBrush}" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,1,0">
                    <Grid Margin="16,18,16,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="MAKRICOLORS PUBLICIDAD" FontSize="18" FontWeight="Black" />
                            <TextBlock Text="Sistema de Inventario" FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,18,0,0">
                            <Button Style="{StaticResource NavButton}" Content="🏠  Dashboard" Click="CloseAndReturn_Click" />
                            <Button Style="{StaticResource NavButton}" Content="📝  Nueva Proforma" Click="OpenNewProforma_Click" />
                            <Border Background="{StaticResource TropicalYellowBrush}" BorderBrush="{StaticResource TropicalOrangeBrush}" BorderThickness="1" CornerRadius="8" Padding="12,9" Margin="0,4,0,0">
                                <TextBlock Text="📦  Inventario" Foreground="{StaticResource BrandDarkBrush}" FontWeight="SemiBold" />
                            </Border>
                            <Button Style="{StaticResource NavButton}" Content="🗂️  Historial" Click="OpenProformaHistory_Click" />
                        </StackPanel>

                        <Button Grid.Row="2"
                                Style="{StaticResource PrimaryButton}"
                                FontWeight="Bold"
                                Content="📝  Nueva Proforma"
                                Click="OpenNewProforma_Click" />
                    </Grid>
                </Border>

                <!-- Main Content -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="70" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Top Bar -->
                    <Border Grid.Row="0" Background="{StaticResource TropicalPinkTintBrush}" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="0,0,0,1">
                        <Grid Margin="20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Height="38" VerticalAlignment="Center" CornerRadius="19" Background="White" BorderBrush="{StaticResource BorderSoftBrush}" BorderThickness="1" Padding="12,0" Width="320">
                                <Grid>
                                    <TextBlock x:Name="txtSearchPlaceholder"
                                               Text="🔍  Buscar por SKU, nombre o categoría..."
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="12"
                                               IsHitTestVisible="False" />
                                    <TextBox x:Name="txtInventorySearch"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             VerticalContentAlignment="Center"
                                             Foreground="{StaticResource TextMainBrush}"
                                             TextChanged="InventorySearch_TextChanged" />
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="📥  Importar BD" Margin="0,0,8,0" Style="{StaticResource GhostButton}" Click="ImportDatabase_Click" />
                                <Button Content="📤  Exportar BD" Style="{StaticResource GhostButton}" Click="ExportDatabase_Click" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Content Area -->
                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="22,18,22,90">
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="LOGÍSTICA Y SUMINISTROS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                        <TextBlock Text="Gestión de Inventario" FontSize="40" FontWeight="Black" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Content="➕  Añadir Producto" Click="AddProduct_Click" Style="{StaticResource PrimaryButton}" />
                                    </StackPanel>
                                </Grid>

                                <!-- KPI Cards -->
                                <UniformGrid Columns="4" Margin="0,0,0,16">
                                    <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                                        <StackPanel>
                                            <TextBlock Text="PRODUCTOS ACTIVOS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock x:Name="txtActiveProducts" Text="0" FontSize="30" FontWeight="Black" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource KpiCard}" Margin="4,0">
                                        <StackPanel>
                                            <TextBlock Text="STOCK TOTAL" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock x:Name="txtTotalStock" Text="0" FontSize="30" FontWeight="Black" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource KpiCard}" Margin="4,0">
                                        <StackPanel>
                                            <TextBlock Text="CATEGORÍAS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock x:Name="txtCategories" Text="0" FontSize="30" FontWeight="Black" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource BrandDarkBrush}" CornerRadius="14" Padding="12" Margin="8,0,0,0" BorderBrush="{StaticResource BrandDarkBrush}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="ALERTA STOCK" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TropicalYellowBrush}" />
                                            <TextBlock x:Name="txtLowStock" Text="0 ítems" FontSize="30" FontWeight="Black" Foreground="White" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <!-- Products Table -->
                                <Border Style="{StaticResource CardBorderStyle}" Padding="0">
                                    <StackPanel>
                                        <Grid Margin="16,10,16,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Listado de productos" FontWeight="Bold" Foreground="{StaticResource BrandDarkBrush}" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button x:Name="btnFilterLowStock"
                                                        Content="⚠️  Filtrar Stock Bajo"
                                                        Height="30"
                                                        Margin="0,0,8,0"
                                                        Padding="10,0"
                                                        Background="White"
                                                        Foreground="{StaticResource BrandDarkBrush}"
                                                        BorderBrush="{StaticResource BrandDarkBrush}"
                                                        Click="FilterLowStock_Click" />
                                                <Button x:Name="btnToggleSort"
                                                        Content="🔤  Ordenar A-Z"
                                                        Height="30"
                                                        Padding="10,0"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Click="ToggleSort_Click" />
                                            </StackPanel>
                                        </Grid>

                                        <DataGrid x:Name="dgProducts"
                                                  Margin="16,0,16,12"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="1.2*" />
                                                <DataGridTextColumn Header="NOMBRE / ESPECIFICACIÓN" Binding="{Binding Name}" Width="3.8*" />
                                                <DataGridTextColumn Header="CATEGORÍA" Binding="{Binding Category}" Width="2*" />
                                                <DataGridTextColumn Header="NIVEL DE STOCK" Binding="{Binding StockDisplay}" Width="2*" />
                                                <DataGridTextColumn Header="PRECIO UNITARIO" Binding="{Binding UnitPriceDisplay}" Width="2*" />
                                                <DataGridTemplateColumn Header="ACCIONES" Width="1.5*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Content="🗑️ Eliminar" Click="DeleteProduct_Click" 
                                                                    Foreground="White" Background="#FF8243"
                                                                    Padding="4,2" Margin="2" Cursor="Hand" BorderThickness="0"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <Grid Margin="16,0,16,10">
                                            <TextBlock x:Name="txtProductsSummary" VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}" Text="Mostrando 0 productos" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
